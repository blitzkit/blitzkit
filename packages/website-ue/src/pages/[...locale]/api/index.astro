---
import "@radix-ui/colors/amber-dark.css";
import { getCollection } from "astro:content";
import ApiGroup from "../../../components/ApiGroup.astro";
import { Heading } from "../../../components/Heading";
import { Section } from "../../../components/Section";
import ToolBanner from "../../../components/ToolBanner.astro";
import { api } from "../../../core/api/dynamic";
import { tools } from "../../../core/tools/tools";
import BaseLayout from "../../../layouts/BaseLayout.astro";

export { getStaticPaths } from "../index.astro";

const { locale } = Astro.props;
const collection = await getCollection("api");
const strings = await api.strings(locale);

const paths: {
  path: string;
  documentation: string;
}[] = [];

paths.sort((a, b) => a.path.localeCompare(b.path));
---

<BaseLayout {locale} accent="brown">
  <ToolBanner {locale} tool={tools.api} slot="pre-app" />

  <Section>
    <Heading>{strings.api.json}</Heading>
    <ApiGroup
      {locale}
      apis={collection.filter((api) => api.id.endsWith(".json"))}
    />
  </Section>

  <Section>
    <Heading>{strings.api.pb}</Heading>
    <ApiGroup
      {locale}
      apis={collection.filter((api) => api.id.endsWith(".pb"))}
    />
  </Section>

  <Section>
    <Heading>{strings.api.media}</Heading>
    <ApiGroup
      {locale}
      apis={collection.filter(
        (api) => !api.id.endsWith(".json") && !api.id.endsWith(".pb"),
      )}
    />
  </Section>
</BaseLayout>
