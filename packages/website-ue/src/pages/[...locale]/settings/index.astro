---
import { Section } from "../../../components/Section";
import ToolBanner from "../../../components/ToolBanner.astro";
import { tools } from "../../../config/tools";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { Page } from "./_index";

export { getStaticPaths } from "../index.astro";

const { locale } = Astro.props;
---

<BaseLayout accent="amber" {locale}>
  <ToolBanner {locale} tool={tools.settings} slot="pre-app" />

  <Section>
    <Page {locale} client:load />
  </Section>
</BaseLayout>
