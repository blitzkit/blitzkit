---
import "@radix-ui/colors/violet-dark.css";
import { Section } from "../../../components/Section";
import ToolBanner from "../../../components/ToolBanner.astro";
import { api } from "../../../core/api/dynamic";
import { tools } from "../../../core/tools/tools";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { Page } from "./_index";

export { getStaticPaths } from "../index.astro";

const { locale } = Astro.props;
const tankList = await api.tankList();
---

<BaseLayout {locale} accent="purple">
  <ToolBanner {locale} tool={tools.tanks} slot="pre-app" />

  <Section>
    <Page {locale} client:load />
  </Section>
</BaseLayout>
