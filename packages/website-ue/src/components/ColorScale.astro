---
import * as colors from "@radix-ui/colors";
import type { Color } from "../core/ui/color";

interface Props {
  color: Color | AlphaOnlyColor;
  alpha?: boolean;
}

const ALPHA_ONLY_COLORS = ["black", "white"] as const;
type AlphaOnlyColor = (typeof ALPHA_ONLY_COLORS)[number];

const { color, alpha } = Astro.props;
const nameLight = `${color}${alpha ? "A" : ""}`;
const nameDark = `${color}${
  ALPHA_ONLY_COLORS.includes(color as AlphaOnlyColor) ? "" : "Dark"
}${alpha ? "A" : ""}`;
const scaleLight = colors[nameLight as keyof typeof colors];
const scaleDark = colors[nameDark as keyof typeof colors];

let styles = "";

styles += ":root.dark{";

for (let i = 0; i < 12; i++) {
  const n = i + 1;
  const value =
    scaleDark[`${color}${alpha ? "A" : ""}${n}` as keyof typeof scaleDark];
  styles += `--${color}-${alpha ? "a" : ""}${n}:${value};`;
}

styles += "}";
styles += ":root.light{";

for (let i = 0; i < 12; i++) {
  const n = i + 1;
  const value =
    scaleLight[`${color}${alpha ? "A" : ""}${n}` as keyof typeof scaleLight];
  styles += `--${color}-${alpha ? "a" : ""}${n}:${value};`;
}

styles += "}";
---

<style set:html={styles}></style>
