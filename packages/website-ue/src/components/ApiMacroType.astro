---
import { resolve } from "path";
import { readFile } from "fs/promises";
import { Link } from "./Link";
import { api } from "../core/api/dynamic";
import HighlightedCodeBlock from "./HighlightedCodeBlock.astro";
import { Text } from "./Text";
import { ArrowBottomRightIcon } from "@radix-ui/react-icons";
import { Code } from "./Code";
import {
  createProgram,
  forEachChild,
  isEnumDeclaration,
  isInterfaceDeclaration,
  isMethodSignature,
  isPropertySignature,
  isTypeAliasDeclaration,
  isTypeReferenceNode,
  type InterfaceDeclaration,
  type Node,
  type TypeNode,
} from "typescript";

interface Props {
  value: string;
  locale: string;
}

const { value, locale } = Astro.props;
const strings = await api.strings(locale);

const lang = "ts";
const roots = ["src/protos", "../closed/protos"];

const [route, name] = value.split(".");
const path = resolve(`${roots[0]}/${route}.ts`);

const program = createProgram([path], {});
const source = program.getSourceFile(path);

if (source === undefined) {
  throw new Error(`Could not find ${path}`);
}

const checker = program.getTypeChecker();
const collected = new Map<string, string>();
let declaration: InterfaceDeclaration | undefined;

forEachChild(source, (node) => {
  if (isInterfaceDeclaration(node) && node.name.text === name) {
    declaration = node;
  }
});

if (declaration === undefined) {
  throw new Error(`Could not find ${name} in ${path}`);
}

function collectNodes(node: Node) {
  if (isInterfaceDeclaration(node)) {
    const symbol = checker.getSymbolAtLocation(node.name);

    if (symbol) {
      const text = node.getText();

      collected.set(node.name.text, text);

      node.members.forEach((member) => {
        if (isPropertySignature(member) && member.type) {
          collectTypes(member.type);
        }
      });
    }
  }

  forEachChild(node, collectNodes);
}

function collectTypes(node: TypeNode) {
  const type = checker.getTypeAtLocation(node);
  const symbol = type.getSymbol();

  if (!symbol) return;

  const name = symbol.getName();

  if (!collected.has(name)) {
    const declarations = symbol.getDeclarations();

    if (declarations) {
      declarations.forEach((declaration) => {
        if (
          !isInterfaceDeclaration(declaration) &&
          !isTypeAliasDeclaration(declaration) &&
          !isEnumDeclaration(declaration)
        ) {
          return;
        }

        const name = declaration.name.text;

        if (collected.has(name)) return;

        collected.set(name, declaration.getText());
        forEachChild(declaration, collectTypesFromNode);
      });
    }
  }
}

function collectTypesFromNode(node: Node) {
  if (isTypeReferenceNode(node)) {
    collectTypes(node);
  }

  forEachChild(node, collectTypesFromNode);
}

collectNodes(declaration);

let content = "";

for (const [, definition] of collected) {
  content += `${definition}\n\n`;
}

content = content.replaceAll(/^export\s*/gm, "");
content = content.trim();
---

<style>
  .macro {
    color: var(--gray-11);

    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .types {
    overflow: hidden;
    display: flex;
    flex-direction: column;

    position: relative;

    &:not([data-expanded="true"]) {
      max-height: 16rem;
    }

    &[data-expanded="true"] {
      .overlay {
        display: none;
      }
    }

    .overlay {
      position: absolute;
      top: 0;
      left: 0;

      width: 100%;
      height: 100%;

      background: linear-gradient(transparent, var(--gray-1));

      display: flex;
      align-items: end;
      justify-content: center;
    }
  }
</style>

<script>
  const viewers = document.querySelectorAll(".view-full");

  for (const viewer of viewers) {
    viewer.addEventListener("click", () => {
      viewer.parentElement!.parentElement!.dataset.expanded = "true";
    });
  }
</script>

<div class="macro">
  <Text lowContrast weight="medium" color="tomato">
    <Code>@types</Code>
  </Text>

  <ArrowBottomRightIcon />
</div>

<div class="types">
  <HighlightedCodeBlock {lang} content={content} />

  <div class="overlay">
    <Link underline="always" href="#" className="view-full">
      {strings.api.view_full}
    </Link>
  </div>
</div>
