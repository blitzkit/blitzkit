---
import type { CollectionEntry } from "astro:content";
import ApiEntry from "./ApiEntry.astro";

interface Props {
  locale: string;
  apis: CollectionEntry<"api">[];
}

const { apis, locale } = Astro.props;
---

{
  apis
    .sort((a, b) => a.id.localeCompare(b.id))
    .map((api) => <ApiEntry {locale} {api} />)
}
