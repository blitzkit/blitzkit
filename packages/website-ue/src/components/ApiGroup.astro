---
import type { CollectionEntry } from "astro:content";
import { api } from "../core/api/dynamic";
import { Code } from "./Code";
import { Heading } from "./Heading";
import { MarkdownCustom } from "./MarkdownCustom";

interface Props {
  locale: string;
  apis: CollectionEntry<"api">[];
}

const { apis, locale } = Astro.props;
const strings = await api.strings(locale);
---

<style>
  .container {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);

    .docs {
      margin-left: var(--space-5);
    }
  }
</style>

{
  apis
    .sort((a, b) => a.id.localeCompare(b.id))
    .map((api) => (
      <div class="container">
        <Heading size="3">
          <Code>{api.id}</Code>
        </Heading>

        <MarkdownCustom
          className="docs"
          body={api.data.docs ?? strings.api.no_docs}
        />
      </div>
    ))
}
