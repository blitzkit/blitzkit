---
import type { CollectionEntry } from "astro:content";
import { api } from "../core/api/dynamic";
import { ApiTester } from "./ApiTester";
import { MarkdownCustom } from "./MarkdownCustom";

interface Props {
  locale: string;
  api: CollectionEntry<"api">;
}

const { locale, api: apiData } = Astro.props;
const strings = await api.strings(locale);
const hasSlugs = apiData.id.includes("[");
---

<style>
  .container {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
</style>

<div class="container">
  <ApiTester client:idle {locale} path={apiData.id} />

  <MarkdownCustom body={apiData.data.docs ?? strings.api.no_docs} />
</div>
