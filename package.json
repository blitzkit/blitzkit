{
  "name": "blitzkit",
  "version": "2.0.0-beta.3",
  "license": "BlitzKit License",
  "private": true,
  "scripts": {
    "build:game": "cd packages/game && bun run build",
    "build:website": "cd packages/website-ue && bun run build",
    "build:proxyclient": "cd packages/scripts && bun run build:proxyclient",
    "build:catalogitemaccesssor": "cd packages/scripts && bun run build:catalogitemaccesssor",
    "build:protos": "cd packages/scripts && bun run build:protos",
    "dev": "bun run dev:website",
    "dev:website": "cd packages/website-ue && bun run dev",
    "lint": "tsc",
    "lint:website": "cd packages/website-ue && bun run lint",
    "setup": "bun install && bun run build:protos && bun run build:proxyclient && bun run build:catalogitemaccesssor"
  },
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "typescript": "^5.9.3"
  }
}
